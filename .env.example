# DeepSeek Balance Monitor Bot — 环境变量配置
# 复制此文件为 .env 后填写真实值：
#   cp .env.example .env
#
# 必填项已取消注释，请填入你的真实信息。
# 可选项默认值可直接使用，如需修改请取消注释后调整。

# === 必填项 ===

# DeepSeek 平台 API Key
# 获取地址：https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Telegram Bot Token（通过 @BotFather 创建）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 目标聊天 ID（数字，从 getUpdates API 获取）
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === 可选项（默认值可直接使用，取消注释可修改） ===

# 轮询间隔（秒），默认 300（5 分钟）
# INTERVAL_SECONDS=300

# 时区偏移（小时），默认 8（北京时间/CST）
# TIMEZONE_OFFSET=8

# 监控的 systemd 服务列表，格式：标签:服务名,标签:服务名
# 默认值：SS:shadowsocks-rust,Bot:deepseek-balance-bot
# MONITOR_SERVICES=SS:shadowsocks-rust,Bot:deepseek-balance-bot

# 查询余额失败时的重试次数，默认 3
# RETRY_COUNT=3

# 重试间隔（秒），默认 5
# RETRY_INTERVAL=5
